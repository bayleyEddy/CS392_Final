@page "/ProductPages/Chatbot"
@model CS392_Demo3.Pages.ProductPages.ChatbotModel
@{
    ViewData["Title"] = "Product Chatbot";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Product Chatbot</title>

    <style>
            body {
                font-family: Arial, sans-serif;
                background: #f5f6f8;
                margin: 0;
                padding: 20px;
            }

            .chat-container {
                width: 80%;
                max-width: 900px;
                margin: auto;
            }

            .chat-box {
                background: white;
                border-radius: 10px;
                padding: 20px;
                height: 500px;
                overflow-y: auto;
                border: 1px solid #ddd;
            }

            .bubble {
                max-width: 70%;
                padding: 12px 16px;
                margin: 10px 0;
                border-radius: 15px;
                line-height: 1.4;
                font-size: 15px;
            }

            .user {
                background: #007bff;
                color: white;
                margin-left: auto;
                text-align: right;
            }

            .ai {
                background: #e0e0e0;
                color: black;
                margin-right: auto;
            }

            .input-area {
                margin-top: 20px;
                display: flex;
                gap: 10px;
            }

            textarea {
                width: 100%;
                height: 60px;
                padding: 10px;
                border-radius: 8px;
                border: 1px solid #aaa;
                resize: none;
            }

            button {
                padding: 10px 20px;
                background: black;
                color: white;
                border: none;
                border-radius: 8px;
                cursor: pointer;
            }

                button:hover {
                    background: #333;
                }
    </style>
</head>

<body>
    <div class="chat-container">
        <h2>Product Chatbot</h2>

        <div id="chatHistory" class="chat-box">
            @foreach (var msg in Model.ChatHistory)
            {
                <div class="bubble @(msg.Role)">
                    @msg.Text
                </div>
            }
        </div>

        <form method="post">
            <div class="input-area">
                <textarea name="UserQuestion" placeholder="Ask something about products..." required></textarea>
                <button type="submit">Send</button>
            </div>
        </form>
    </div>

    <script>
            // Auto-scroll to bottom
            var chatBox = document.getElementById("chatHistory");
            chatBox.scrollTop = chatBox.scrollHeight;
    </script>
</body>
</html>
