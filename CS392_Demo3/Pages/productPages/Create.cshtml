@page "/ProductPages/Create"
@model CS392_Demo3.Pages.ProductPages.CreateModel

<h2>Create Product</h2>

<div asp-validation-summary="All" class="text-danger"></div>

<form method="post">
    @Html.AntiForgeryToken()

    <div class="form-group">
        <label>Name</label>
        <input asp-for="Product.name" class="form-control" />
        <span asp-validation-for="Product.name" class="text-danger"></span>
    </div>

    <div class="form-group mt-2">
        <div class="form-check">
            <input asp-for="Product.inStock" class="form-check-input" type="checkbox" />
            <label asp-for="Product.inStock" class="form-check-label">In Stock</label>
        </div>
    </div>

    <div class="form-group">
        <label>Category</label>
        <input asp-for="Product.category" class="form-control" />
    </div>

    <div class="form-group">
        <label>Price</label>
        <input asp-for="Product.price" class="form-control" />
    </div>

    <div class="form-group">
        <label>Tags (comma separated)</label>
        <input asp-for="Product.tagsString" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success mt-3">Create</button>
    <a asp-page="Index" class="btn btn-secondary mt-3">Cancel</a>
</form>